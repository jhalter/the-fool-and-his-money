on prepareFrame
  [  0] pushint8 1 .............................. <1>
  [  2] pusharglist 1 ........................... <1>
  [  4] extcall 8 ............................... <sprite(1)>
  [  6] getobjprop 9 ............................ <sprite(1).visible>
  [  8] pushzero ................................ <0>
  [  9] eq ...................................... <sprite(1).visible = 0>
  [ 10] jmpifz [ 23] ............................ if sprite(1).visible = 0 then
  [ 13] pushint8 1 .............................. <1>
  [ 15] pusharglist 1 ........................... <1>
  [ 17] extcall 8 ............................... <sprite(1)>
  [ 19] pushint8 1 .............................. <1>
  [ 21] setobjprop 9 ............................ sprite(1).visible = 1
  [ 23] ret
end

on exitFrame
  [  0] pusharglistnoret 0 ...................... <>
  [  2] extcall 10 .............................. pro_Play_4()
  [  4] ret
end
