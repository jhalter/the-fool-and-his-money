  [ 10] getglobal 45 ............................ <playMode>
  [ 12] getglobal 78 ............................ <pmActivate>
  [ 14] eq ...................................... <playMode = pmActivate>
  [ 15] jmpifz [ 25] ............................ if playMode = pmActivate then
  [ 18] getglobal 21 ............................ <cGameMenus>
  [ 20] pushzero ................................ <0>
  [ 21] pusharglistnoret 2 ...................... <cGameMenus, 0>
  [ 23] extcall 20 .............................. initLaunch(cGameMenus, 0)
  [ 25] ret
end

on pro_Quit
  [  0] pushint8 99 ............................. <99>
  [  2] setglobal 24 ............................ currPuzzle = 99
  [  4] gettoplevelprop 14 ...................... <_movie>
  [  6] gettoplevelprop 14 ...................... <_movie>
  [  8] getobjprop 44 ........................... <_movie.frame>
  [ 10] pusharglistnoret 2 ...................... <_movie, _movie.frame>
  [ 12] objcall 18 .............................. _movie.go(_movie.frame)
  [ 14] getglobal 45 ............................ <playMode>
  [ 16] getglobal 78 ............................ <pmActivate>
  [ 18] eq ...................................... <playMode = pmActivate>
  [ 19] jmpifz [ 29] ............................ if playMode = pmActivate then
  [ 22] getglobal 21 ............................ <cGameMenus>
  [ 24] pushzero ................................ <0>
  [ 25] pusharglistnoret 2 ...................... <cGameMenus, 0>
  [ 27] extcall 20 .............................. initLaunch(cGameMenus, 0)
  [ 29] ret
end
