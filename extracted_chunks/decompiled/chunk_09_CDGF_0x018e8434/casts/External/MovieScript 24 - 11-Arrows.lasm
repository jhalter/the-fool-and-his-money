on arrow_F_Show f
  [  0] getglobal 32 ............................ <F_Arrow_Active>
  [  2] pushint8 1 .............................. <1>
  [  4] eq ...................................... <F_Arrow_Active = 1>
  [  5] getglobal 449 ........................... <menu_Key>
  [  8] pushcons 0 .............................. <"--------">
  [ 10] nteq .................................... <menu_Key <> "--------">
  [ 11] and ..................................... <(F_Arrow_Active = 1) and (menu_Key <> "--------")>
  [ 12] jmpifz [ 52] ............................ if (F_Arrow_Active = 1) and (menu_Key <> "--------") then
  [ 15] getparam 0 .............................. <f>
  [ 17] pushzero ................................ <0>
  [ 18] eq ...................................... <f = 0>
  [ 19] jmpifz [ 41] ............................ if f = 0 then
  [ 22] getglobal 55 ............................ <currRollOver>
  [ 24] getglobal 58 ............................ <cForwardSN>
  [ 26] eq ...................................... <currRollOver = cForwardSN>
  [ 27] jmpifz [ 37] ............................ if currRollOver = cForwardSN then / else
  [ 30] pushint8 2 .............................. <2>
  [ 32] setparam 0 .............................. f = 2
  [ 34] jmp [ 41]
  [ 37] pushint8 1 .............................. <1>
  [ 39] setparam 0 .............................. f = 1
  [ 41] getglobal 58 ............................ <cForwardSN>
  [ 43] getparam 0 .............................. <f>
  [ 45] pushint8 1 .............................. <1>
  [ 47] pusharglistnoret 3 ...................... <cForwardSN, f, 1>
  [ 49] extcall 396 ............................. misc_UpdateStaticSprite(cForwardSN, f, 1)
  [ 52] ret
end

