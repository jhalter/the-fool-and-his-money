end

on launch_Range n1, n2
  [  0] getparam 0 .............................. <n1>
  [  2] setlocal 0
  [  4] getlocal 0
  [  6] getparam 1 .............................. <n2>
  [  8] lteq
  [  9] jmpifz [ 27] ............................ repeat with x = n1 to n2
  [ 12] getlocal 0 .............................. <x>
  [ 14] pusharglistnoret 1 ...................... <x>
  [ 16] localcall 4 ............................. pz_Grab(x)
  [ 18] pushint8 1
  [ 20] getlocal 0
  [ 22] add
  [ 23] setlocal 0
  [ 25] endrepeat [  4]
  [ 27] ret
end

